<%- include("head.part.ejs") %>
<main>
    <h2>GENERAL ECONOMIC OVERVIEW</h2>
    <table>
        <tr>
        <th>MARKET SELL ORDER VALUE</th>
        <th>MARKET BUY ORDER VALUE</th>
        </tr>
        <tr>
            <td><%= data.sell_order_value%></td>
            <td><%= data.buy_order_value%></td>
        </tr>
    </table>
    <h2>TOTAL MARKET BALANCE</h2>
    <table>
        <th class="<%= data.market_balance > 0 ? 0 : 'red_cell' %>""><%= data.market_balance %></th>    
    </table>
    <div>
        <h2>Most Valuable Goods</h2>
        <table>
            <tr>
                <th>Name</th>
                <th>Per Unit Price</th>
                <th>Yearly Production</th>
                <th>Yearly Consumption</th>
                <th>Gross Worth</th>
            </tr>
            <% data.most_valuable.forEach(function(good) {%>
                <tr>
                <td><%= good.name %></td>
                <td><%= good.unit_price %></td>
                <td><%= good.yearly_production %></td>
                <td><%= good.yearly_consumption %></td>
                <td><%= good.worth %></td>
            </tr>
            <%});%>
        </table>
        <h2>Highest Deficit Goods</h2>
        <table>
            <tr>
                <th>Name</th>
                <th>Per Unit Price</th>
                <th>Yearly Production</th>
                <th>Yearly Consumption</th>
                <th>Yearly Balance</th>
            </tr>
            <% data.highest_deficits.forEach(function(good) {%>
                <tr>
                <td><%= good.name %></td>
                <td><%= good.unit_price %></td>
                <td><%= good.yearly_production %></td>
                <td><%= good.yearly_consumption %></td>
                <td><%= good.yearly_balance %></td>
            </tr>
            <%});%>
        </table>
    </div>
</main>