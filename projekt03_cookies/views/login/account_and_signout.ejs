<h3>Welcome, Employee <%= locals.user.username%></h3>
<h4>
    <% if(locals.user.department_name != null){ %>
        <%=locals.user.department_name%> Department
    <%} else {%>
        <%="You do not have any department assigned. Consult your administrator (assign department/permission from admin account.)"%>
    <%}%>
</h4>
<% if(locals.user.permissions.admin == 'yes'){%>
    <%- include("../admin/admin_header.ejs")%>
<%}%>
<a href="/logout">Log out</a>